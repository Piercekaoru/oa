{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@openachieve/ai": ["./packages/ai/src/index.ts"],
			"@openachieve/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@openachieve/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@openachieve/ai/dist/*": ["./packages/ai/src/*"],
			"@openachieve/agent-core": ["./packages/agent/src/index.ts"],
			"@openachieve/agent-core/*": ["./packages/agent/src/*"],
			"@openachieve/agent": ["./packages/coding-agent/src/index.ts"],
			"@openachieve/agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@openachieve/agent/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@openachieve/tui": ["./packages/tui/src/index.ts"],
			"@openachieve/tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["**/dist/**"]
}
